<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page</title>
</head>
<body>
    <!DOCTYPE html>
<html lang="hi">
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container">
        <div class="row justify-content-center mt-5">
            <div class="col-md-4">
                <form class="bg-white p-4 shadow rounded" action="/login" method="post">
                    <h3 class="text-center mb-4">Login</h3>
                    <div class="mb-3">
                        <label>Student: </label>
                        <input type="text" class="form-control" name = "name" placeholder="Enter your name" required>
                    </div>
                    <div class="mb-3">
                        <label>Email: </label>
                        <input type="email" class="form-control" name = "email" placeholder="Email" required>
                    </div>
                    <div class="mb-3">
                        <label>Password: </label>
                        <input type="password" class="form-control" name = "password" placeholder="Password" required>
                    </div>
                    <div class="mb-3">
                        <label>Registration Id: </label>
                        <input type="password" class="form-control" name = "id" placeholder="Registration Id" required>
                    </div>
                    <div class="mb-3">
                        <label>Class: </label>
                        <input type="text" class="form-control"  name = "class" placeholder="Class" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>

</body>
</html>