<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>College Management</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <nav class="navbar navbar-expand-lg px-4 py-0 bg-dark">
      <div class="container-fluid">
        <button
          class="navbar-toggler"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#navbarSupportedContent"
          aria-controls="navbarSupportedContent"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link active text-light" aria-current="page" href="#"
                >Home</a
              >
            </li>
            <li class="nav-item">
              <a class="nav-link text-light" href="http://localhost:5500/login">Add Student</a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-light" href="">Update Student</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <h3 class="p-3">Dashboard</h3>
    <div class="card mx-2 rounded-3 bg-secondary">
      <h5 class="card-title mx-4 mt-2">Quick Stats</h5>
      <div class="card-body d-flex gap-3 p-0">
          <div class="border border-secondary d-inline-block w-25 px-4 rounded-3 bg-danger">
            <p class=" lead">Total Students</p>
            <h2 id="student"><%= total %></h2>
          </div>
          <div class="border border-secondary d-inline-block w-25 px-4 rounded-3 bg-warning">
            <p class=" lead">Total Teachers</p>
            <h2>00</h2>
          </div>
          <div class="border border-secondary d-inline-block w-25 px-4 rounded-3 bg-success">
            <p class=" lead">Classes Today</p>
            <h2>45</h2>
          </div>
          <div class="border border-secondary d-inline-block w-25 px-4 rounded-3 bg-info">
            <p class=" lead">Pending Enrollments</p>
            <h2>15</h2>
          </div>
        </div>
      </div>
    </div>

    <div class=" card mx-2 mt-4 rounded-3" style="width: 100%;">
      <h5 class=" mx-2 mt-2">Recent Student Enrollments</h5>
      <table class="table table-hover table-striped table-dark" id="table">
        <thead>
          <tr class="table-active table-primary">
            <th scope="col">Student Name</th>
            <th scope="col">E-Mail</th>
            <th scope="col">Password</th>
            <th scope="col">Registration Id</th>
            <th scope="col">Class</th>
            <th>Action</th>
          </tr>
        </thead>
        
        <tbody>
          <% for(let student of data) { %>
          <tr>
            <td><%= student.studentName %></td>
            <td><%= student.email %></td>
            <td><%= student.password %></td>
            <td><%= student.registrationId %></td>
            <td><%= student.class %></td>
            <td>
              <a href="/delete/<%= student.registrationId %>"
                class="btn btn-outline-info btn-sm" 
                onclick="return confirm('Are you sure?')">
                Delete
              </a>
              <a href="http://localhost:5500/edit/<%= student.registrationId %>"
                class="btn btn-danger btn-sm">
                Edit
              </a>
            </td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
    
  </body>
</html>
